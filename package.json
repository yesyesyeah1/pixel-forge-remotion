{
    "name": "pixel-forge-remotion",
    "version": "1.0.0",
    "description": "AI-powered SaaS web design agency - Programmatic video ad generation with Remotion + React",
    "scripts": {
          "start": "npx remotion studio",
          "build": "npx remotion render SaasShowcase out/saas-showcase.mp4",
          "build:before-after": "npx remotion render BeforeAfter out/before-after.mp4",
          "build:metric": "npx remotion render MetricHighlight out/metric-highlight.mp4",
          "build:testimonial": "npx remotion render TestimonialAd out/testimonial.mp4",
          "build:all": "npm run build && npm run build:before-after && npm run build:metric && npm run build:testimonial",
          "render-client": "ts-node render.ts"
    },
    "dependencies": {
          "@remotion/cli": "^4.0.0",
          "@remotion/player": "^4.0.0",
          "react": "^18.2.0",
          "react-dom": "^18.2.0",
          "remotion": "^4.0.0",
          "zod": "^3.22.0"
    },
    "devDependencies": {
          "@remotion/bundler": "^4.0.0",
          "@types/react": "^18.2.0",
          "typescript": "^5.3.0",
          "ts-node": "^10.9.0"
    }
}
