{
    "compilerOptions": {
          "target": "ES2018",
          "module": "commonjs",
          "jsx": "react-jsx",
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "forceConsistentCasingInFileNames": true,
          "outDir": "./dist",
          "rootDir": "./src",
          "declaration": true
    },
    "include": ["src/**/*", "render.ts", "remotion.config.ts"],
    "exclude": ["node_modules", "dist", "out"]
}
